<Window x:Class="QuickBTTrayApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Background="Transparent"
        Topmost="True">

    <Border CornerRadius="8"
            Padding="0,6"
            Background="{DynamicResource MenuBackground}">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="3" Opacity="0.4"/>
        </Border.Effect>

        <StackPanel MinWidth="200">

            <!-- ── Header ── -->
            <Grid Margin="8,4,8,4">
                <TextBlock Text="Settings"
                           Foreground="{DynamicResource MenuForeground}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>
            </Grid>

            <!-- ── Divider ── -->
            <Rectangle Height="1" Fill="{DynamicResource SeparatorBrush}" Margin="10,2,10,4"/>

            <!-- ── Start with Windows toggle ── -->
            <Button Command="{Binding ToggleRunOnStartupCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Cursor="Hand"
                    Padding="10,5"
                    Margin="4,1,4,4">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource RowHoverBackground}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding RunOnStartup, Mode=TwoWay}"
                              IsHitTestVisible="False"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                    <TextBlock Text="Start with Windows"
                               Foreground="{DynamicResource MenuForeground}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </StackPanel>
    </Border>
</Window>
