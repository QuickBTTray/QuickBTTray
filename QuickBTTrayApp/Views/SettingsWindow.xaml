<Window x:Class="QuickBTTrayApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:QuickBTTrayApp.Converters"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Background="Transparent"
        Topmost="True">

    <Border Margin="8"
            CornerRadius="8"
            Padding="0,6"
            Background="{DynamicResource MenuBackground}">
        <Border.Resources>
            <conv:EnumToBoolConverter x:Key="EnumToBool"/>
            <Style TargetType="ToolTip">
                <Setter Property="Background" Value="{DynamicResource MenuBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource MenuForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SeparatorBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Placement" Value="Right"/>
                <Setter Property="HasDropShadow" Value="True"/>
            </Style>
        </Border.Resources>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="3" Opacity="0.4"/>
        </Border.Effect>
        <StackPanel Grid.IsSharedSizeScope="True">

            <!-- ── Header ── -->
            <Grid Margin="8,4,8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Settings"
                           Foreground="{DynamicResource MenuForeground}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>
                <Button Grid.Column="1"
                        Command="{Binding OpenGitHubCommand}"
                        Cursor="Hand"
                        Padding="4,2">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource RowHoverBackground}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.ToolTip>
                        <ToolTip>
                            <TextBlock Text="https://github.com/QuickBTTray/QuickBTTray"/>
                        </ToolTip>
                    </Button.ToolTip>
                    <TextBlock Text="{Binding AppVersion}"
                               Foreground="#0A66D8"
                               FontSize="11"
                               VerticalAlignment="Center"
                               TextDecorations="Underline"/>
                </Button>
            </Grid>

            <!-- ── Divider ── -->
            <Rectangle Height="1" Fill="{DynamicResource SeparatorBrush}" Margin="10,2,10,4"/>

            <!-- ── Notifications toggle ── -->
            <Button Command="{Binding ToggleNotificationsCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Cursor="Hand"
                    Padding="10,5"
                    Margin="4,1,4,1">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource RowHoverBackground}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding NotificationsEnabled, Mode=TwoWay}"
                              IsHitTestVisible="False"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                    <TextBlock Text="Windows Notifications"
                               Foreground="{DynamicResource MenuForeground}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- ── Start with Windows toggle ── -->
            <Button Command="{Binding ToggleRunOnStartupCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Cursor="Hand"
                    Padding="10,5"
                    Margin="4,1,4,4">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource RowHoverBackground}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding RunOnStartup, Mode=TwoWay}"
                              IsHitTestVisible="False"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                    <TextBlock Text="Start with Windows"
                               Foreground="{DynamicResource MenuForeground}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- ── Media play on connect toggle ── -->
            <Button Command="{Binding ToggleSendMediaPlayOnConnectCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Cursor="Hand"
                    Padding="10,5"
                    Margin="4,1,4,4">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource RowHoverBackground}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding SendMediaPlayOnConnect, Mode=TwoWay}"
                              IsHitTestVisible="False"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                    <TextBlock Text="On Connect send Media Play"
                               Foreground="{DynamicResource MenuForeground}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- ── Media pause on disconnect toggle ── -->
            <Button Command="{Binding ToggleSendMediaPauseOnDisconnectCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Cursor="Hand"
                    Padding="10,5"
                    Margin="4,1,4,4">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource RowHoverBackground}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding SendMediaPauseOnDisconnect, Mode=TwoWay}"
                              IsHitTestVisible="False"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                    <TextBlock Text="On Disconnect send Media Pause"
                               Foreground="{DynamicResource MenuForeground}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

                       <!-- ── Divider ── -->
            <Rectangle Height="1" Fill="{DynamicResource SeparatorBrush}" Margin="10,4,10,4"/>

            <!-- ── Connect via ── -->
            <Grid Margin="10,2,4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="78" SharedSizeGroup="SettingsLabel"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsPrimaryOption"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsSecondaryOption"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Connect via:"
                           Foreground="{DynamicResource MenuForeground}"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="1" Margin="0,1,2,1" CornerRadius="4" Cursor="Hand" PreviewMouseLeftButtonDown="RadioOptionBorder_PreviewMouseLeftButtonDown">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock>Uses the Win32 Bluetooth API for connection</TextBlock>
                        </ToolTip>
                    </Border.ToolTip>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource RowHoverBackground}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <RadioButton Content="API"
                                 IsChecked="{Binding ConnectBy, Converter={StaticResource EnumToBool}, ConverterParameter=API, Mode=TwoWay}"
                                 Foreground="{DynamicResource MenuForeground}"
                                 VerticalAlignment="Center"
                                 Padding="5,2"/>
                </Border>
                <Border Grid.Column="2" Margin="0,1" CornerRadius="4" Cursor="Hand" PreviewMouseLeftButtonDown="RadioOptionBorder_PreviewMouseLeftButtonDown">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock>Uses UI Automation for native Windows Connect button behaviour</TextBlock>
                        </ToolTip>
                    </Border.ToolTip>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource RowHoverBackground}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <RadioButton Content="UI"
                                 IsChecked="{Binding ConnectBy, Converter={StaticResource EnumToBool}, ConverterParameter=UI, Mode=TwoWay}"
                                 Foreground="{DynamicResource MenuForeground}"
                                 VerticalAlignment="Center"
                                 Padding="5,2"/>
                </Border>
            </Grid>

            <!-- ── Disconnect via ── -->
            <Grid Margin="10,2,4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="78" SharedSizeGroup="SettingsLabel"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsPrimaryOption"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsSecondaryOption"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Disconnect via:"
                           Foreground="{DynamicResource MenuForeground}"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="1" Margin="0,1,2,1" CornerRadius="4" Cursor="Hand" PreviewMouseLeftButtonDown="RadioOptionBorder_PreviewMouseLeftButtonDown">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock>Sends a low-level HCI disconnect to fully drop the Bluetooth link</TextBlock>
                        </ToolTip>
                    </Border.ToolTip>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource RowHoverBackground}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <RadioButton Content="HCI"
                                 IsChecked="{Binding DisconnectBy, Converter={StaticResource EnumToBool}, ConverterParameter=HCI, Mode=TwoWay}"
                                 Foreground="{DynamicResource MenuForeground}"
                                 VerticalAlignment="Center"
                                 Padding="5,2"/>
                </Border>
                <Border Grid.Column="2" Margin="0,1" CornerRadius="4" Cursor="Hand" PreviewMouseLeftButtonDown="RadioOptionBorder_PreviewMouseLeftButtonDown">
                    <Border.ToolTip>
                        <ToolTip>
                            <TextBlock>Uses UI Automation for native Windows Disconnect button behaviour</TextBlock>
                        </ToolTip>
                    </Border.ToolTip>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource RowHoverBackground}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <RadioButton Content="UI"
                                 IsChecked="{Binding DisconnectBy, Converter={StaticResource EnumToBool}, ConverterParameter=UI, Mode=TwoWay}"
                                 Foreground="{DynamicResource MenuForeground}"
                                 VerticalAlignment="Center"
                                 Padding="5,2"/>
                </Border>
            </Grid>

        </StackPanel>
    </Border>
</Window>
