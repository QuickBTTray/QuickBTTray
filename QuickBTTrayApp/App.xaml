<Application x:Class="QuickBTTrayApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Add other resource dictionaries here if needed -->
            </ResourceDictionary.MergedDictionaries>
            <tb:TaskbarIcon x:Key="TrayIcon"
                            xmlns:tb="http://www.hardcodet.net/taskbar"
                            IconSource="pack://application:,,,/Views/Assets/icon.ico"
                            ToolTipText="QuickBTTrayApp"
                            MenuActivation="RightClick">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <!-- Bluetooth Devices Section -->
                        <MenuItem Header="[ ] BT Device 3   [status]   [Connect] [Disconnect]" IsEnabled="False"/>
                        <MenuItem Header="[ ] BT Device 2   [status]   [Connect] [Disconnect]" IsEnabled="False"/>
                        <MenuItem Header="[ ] BT Device 1   [status]   [Connect] [Disconnect]" IsEnabled="False"/>
                        <Separator/>
                        <!-- Connection Method Section -->
                        <MenuItem Header="Connect by:    (•) UI   ( ) API" IsEnabled="False"/>
                        <MenuItem Header="Disconnect by: (•) UI   ( ) API" IsEnabled="False"/>
                        <Separator/>
                        <!-- Exit Option -->
                        <MenuItem Header="Exit" Click="TrayMenu_Exit_Click"/>
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
        </ResourceDictionary>
    </Application.Resources>
</Application>
